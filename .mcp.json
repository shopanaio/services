{
  "mcpServers": {
    "shopana-cli": {
      "command": "node",
      "args": ["./packages/shopana-cli-mcp/dist/index.js"]
    },
    "shopana-index": {
      "command": "npx",
      "args": ["@zaytra/indexmcp"]
    },
    "antd": {
      "command": "npx",
      "args": ["-y", "@jzone-mcp/antd-components-mcp"]
    },
    "ag-mcp": {
      "command": "npx",
      "args": ["ag-mcp"]
    }
  }
}
