{
  "foam.edit.linkReferenceDefinitions": "withExtensions",
  "foam.files.exclude": [".index/**", ".vscode/**", ".foam/**", "node_modules/**"],
  "foam.graph.style": {
    "background": "#1e1e1e",
    "node": {
      "note": "#6699ff",
      "placeholder": "#ff6666",
    },
  },
  "foam.links.sync.enable": true,

  "editor.wordWrap": "on",
  "editor.quickSuggestions": {
    "comments": false,
    "strings": false,
    "other": true,
  },
  "files.exclude": {
    ".index": true,
  },
  "[markdown]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true,
    "editor.tabSize": 2,
  },
  "terminal.integrated.defaultLocation": "panel",
  "terminal.integrated.fontSize": 13,
  "terminal.integrated.lineHeight": 1.2,
  "json.schemas": [
    {
      "fileMatch": ["**/build.config.json"],
      "url": "./packages/cli/schemas/build.config.schema.json",
    },
  ],
}
