    "foam.files.exclude": [".index/**", ".vscode/**", ".foam/**"],
    "foam.graph.style": {
      "background": "#1e1e1e",
      "node": {
        "note": "#6699ff",
        "placeholder": "#ff6666"
      }
    }
  },
  "extensions": {
    "recommendations": [
      "foam.foam-vscode",
      "yzhang.markdown-all-in-one",
      "esbenp.prettier-vscode"
    ]
  }
}
