{
  "name": "@shopana/dbos",
  "version": "1.0.0",
  "type": "module",
  "description": "Durable workflow and saga framework built on DBOS SDK",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts",
      "default": "./src/index.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "test": "NODE_OPTIONS=--experimental-vm-modules jest",
    "test:watch": "NODE_OPTIONS=--experimental-vm-modules jest --watch"
  },
  "keywords": [
    "dbos",
    "workflow",
    "saga",
    "durable",
    "orchestration"
  ],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^20.12.7",
    "jest": "^30.1.3",
    "ts-jest": "^29.4.6",
    "typescript": "^5.4.5"
  },
  "dependencies": {
    "@dbos-inc/dbos-sdk": "^4.7.9",
    "@nestjs/common": "^10.0.0",
    "canonicalize": "^1.0.8",
    "reflect-metadata": "^0.2.2"
  },
  "peerDependencies": {
    "@nestjs/core": "^10.0.0"
  }
}
