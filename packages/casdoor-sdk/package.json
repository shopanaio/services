{
  "name": "@zaytra/casdoor-node-client-ext",
  "version": "0.1.0-alpha.0",
  "description": "Node.js (TypeScript) extension client for Casdoor built on top of casdoor-nodejs-sdk (adds browser /api endpoints).",
  "private": true,
  "type": "module",
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/types/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.esm.json && tsc -p tsconfig.cjs.json && node ./scripts/postbuild.mjs",
    "type-check": "tsc -p tsconfig.esm.json --noEmit"
  },
  "dependencies": {
    "axios": "^1.8.4",
    "casdoor-nodejs-sdk": "^1.34.0",
    "form-data": "^4.0.0"
  }
}
