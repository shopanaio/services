{
  "name": "@zaytra/casdoor-node-client-ext",
  "version": "0.1.0-alpha.0",
  "description": "Node.js (TypeScript) extension client for Casdoor built on top of casdoor-nodejs-sdk (adds browser /api endpoints).",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "node ../esbuild.js",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "axios": "^1.8.4",
    "casdoor-nodejs-sdk": "^1.34.0",
    "form-data": "^4.0.0"
  },
  "devDependencies": {
    "rimraf": "^5.0.0",
    "typescript": "^5.5.4"
  }
}
