# Bootstrap Configuration
# All configuration is loaded from config.yml
# Environment variables can be used to override specific settings

# RabbitMQ connection
# RABBITMQ_URL=amqp://localhost:5672

# Optional: Override log level (default from config.yml)
# LOG_LEVEL=debug

# Optional: Override metrics port (default: 3030)
# METRICS_PORT=3030

# Optional: Override environment
# NODE_ENV=development

# Platform gRPC host
# PLATFORM_GRPC_HOST=platform:50051
