{
  "entryPoint": "src/orders.module.ts",
  "graphql": {
    "admin": [
      "src/interfaces/gql-admin-api/schema/**/*.graphql",
      "../../packages/shared-references/graphql/**/*.graphql"
    ],
    "storefront": [
      "src/interfaces/gql-storefront-api/schema/**/*.graphql",
      "../../packages/shared-references/graphql/**/*.graphql"
    ]
  },
  "assets": [
    {
      "include": "src/interfaces/gql-admin-api/schema/**/*.graphql",
      "outDir": "dist/schema/admin"
    },
    {
      "include": "src/interfaces/gql-storefront-api/schema/**/*.graphql",
      "outDir": "dist/schema/storefront"
    },
    {
      "include": "../../packages/shared-references/graphql/**/*.graphql",
      "outDir": "dist/schema"
    }
  ]
}
