{
  "entryPoint": "src/iam.module.ts",
  "migrations": { "path": "migrations", "type": "drizzle" },
  "graphql": {
    "admin": [
      "src/api/graphql-admin/schema/**/*.graphql",
      "../../packages/shared-references/graphql/**/*.graphql"
    ]
  },
  "assets": [
    {
      "include": "src/api/graphql-admin/schema/**/*.graphql",
